{
  "name": "memok-ai-openclaw",
  "version": "0.1.1",
  "description": "OpenClaw gateway extension for Memok memory (npm package memok-ai-openclaw; core library: memok-ai)",
  "main": "dist/plugin.js",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24",
      "minGatewayVersion": "2026.3.24"
    },
    "build": {
      "openclawVersion": "2026.3.24",
      "pluginSdkVersion": "2026.3.24"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "ci": "npm run lint && npm run build && npm run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "memok-ai contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "config.toml.example",
    "LICENSE"
  ],
  "dependencies": {
    "@iarna/toml": "^3.0.0",
    "@sinclair/typebox": "^0.34.49",
    "croner": "^10.0.1",
    "memok-ai": "^0.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
