# Example Memok pipeline config (MemokPipelineConfig)
# Live path (written by the plugin): ~/.openclaw/extensions/memok-ai/config.toml
# Generate: run `openclaw memok setup` in the gateway environment (merges optional keys from openclaw.json).
# Do not commit real secrets; copy this file and replace placeholders.
# 中文：示例配置；真实路径见上，向导可生成。

# --- Required ---
dbPath = "~/.openclaw/extensions/memok-ai/memok.sqlite"
openaiApiKey = "REPLACE_ME"
llmModel = "gpt-4o-mini"

# --- Common required numbers (wizard defaults; adjust as needed) ---
llmMaxWorkers = 1
articleSentencesMaxOutputTokens = 8192
coreWordsNormalizeMaxOutputTokens = 32768
sentenceMergeMaxCompletionTokens = 2048

# --- Optional: OpenAI-compatible Base URL (Zhipu / DeepSeek / self-hosted); omit for SDK default ---
# openaiBaseUrl = "https://api.openai.com/v1"

# --- Optional: skip some LLM structured parsing (boolean; default false) ---
# skipLlmStructuredParse = false

# --- Optional: initial weight / duration for new sentences from article-word (positive int; omit for memok-ai defaults) ---
# articleWordImportInitialWeight = 1
# articleWordImportInitialDuration = 7

# --- Optional: predream short→long-term minimum weight threshold (positive int; core default 7) ---
# dreamShortTermToLongTermWeightThreshold = 7

# --- Optional: max LLM retry attempts for relevance scoring (positive int; core default 5, max 32) ---
# relevanceScoreMaxLlmAttempts = 5
