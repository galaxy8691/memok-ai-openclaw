# Memok 管线配置示例（MemokPipelineConfig）
# 实际路径由 OpenClaw 插件写入：~/.openclaw/extensions/memok-ai/config.toml
# 生成方式：在网关环境执行 `openclaw memok setup`（向导会合并 openclaw.json 中的可选项并写本文件）
# 请勿将含真实密钥的文件提交到 git；复制本示例后替换占位值

# --- 必填 ---
dbPath = "~/.openclaw/extensions/memok-ai/memok.sqlite"
openaiApiKey = "REPLACE_ME"
llmModel = "gpt-4o-mini"

# --- 常用必填数值（与向导默认值一致；可按需改）---
llmMaxWorkers = 1
articleSentencesMaxOutputTokens = 8192
coreWordsNormalizeMaxOutputTokens = 32768
sentenceMergeMaxCompletionTokens = 2048

# --- 可选：OpenAI 兼容网关 Base URL（智谱 / DeepSeek / 自建等）；不设则用 SDK 默认 ---
# openaiBaseUrl = "https://api.openai.com/v1"

# --- 可选：跳过部分 LLM 结构化解析（布尔；默认 false）---
# skipLlmStructuredParse = false

# --- 可选：article-word 新插入 sentences 的初始 weight / duration（正整数；省略则由 memok-ai 默认）---
# articleWordImportInitialWeight = 1
# articleWordImportInitialDuration = 7

# --- 可选：predream 中短期句升为长期的最小 weight 阈值（正整数；省略则核心默认 7）---
# dreamShortTermToLongTermWeightThreshold = 7
